    "在 Jupyter 或 Terminal 中直接调用模型："
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "os.environ[\"HF_ENDPOINT\"] = \"https://hf-mirror.com\"\n",
    "os.environ[\"HF_HUB_DISABLE_SSL_VERIFY\"] = \"1\"\n",
    "\n",
    "import torch\n",
    "from transformers import AutoModelForCausalLM, AutoTokenizer\n",
    "\n",
    "tokenizer = AutoTokenizer.from_pretrained(\"/gemini/pretrain\", trust_remote_code=True)\n",
    "model = AutoModelForCausalLM.from_pretrained(\n",
    "    \"/gemini/pretrain\",\n",
    "    dtype=torch.bfloat16,\n",
    "    device_map=\"auto\",\n",
    "    trust_remote_code=True,\n",
    ")\n",
    "print(f\"Model loaded on: {model.device}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def chat(user_message, history=None, temperature=1.0, max_new_tokens=2048):\n",
    "    messages = []\n",
    "    if history:\n",
    "        for q, a in history:\n",
    "            messages.append({\"role\": \"user\", \"content\": q})\n",
    "            messages.append({\"role\": \"assistant\", \"content\": a})\n",
    "    messages.append({\"role\": \"user\", \"content\": user_message})\n",
    "\n",
    "    tokenized = tokenizer.apply_chat_template(\n",
    "        messages,\n",
    "        add_generation_prompt=True,\n",
    "        tokenize=True,\n",
    "        return_tensors=\"pt\",\n",
    "    ).to(model.device)\n",
    "\n",
    "    input_len = tokenized.shape[-1]\n",
    "\n",
    "    with torch.no_grad():\n",
    "        generated = model.generate(\n",
    "            tokenized,\n",
    "            max_new_tokens=max_new_tokens,\n",
    "            temperature=temperature,\n",
    "            do_sample=temperature > 0.01,\n",
    "            top_k=50,\n",
    "            pad_token_id=tokenizer.eos_token_id,\n",
    "        )\n",
    "\n",
    "    output_tokens = generated[0][input_len:]\n",
    "    response = tokenizer.decode(output_tokens, skip_special_tokens=True)\n",
    "    print(f\"Generated {len(output_tokens)} tokens\")\n",
    "    return response\n",
    "\n",
    "result = chat(\"Prove that sqrt(2) is irrational.\")\n",
    "print(result)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "\n",
    "## 六、常见问题\n",
    "\n",
    "### Q: 为什么启动需要等 4-7 分钟？\n",
    "A: 模型需要加载 4 个 safetensors 文件（共 16.5GB）到 GPU 显存，每次启动推理服务都会重新加载。\n",
    "\n",
    "### Q: 这个项目启动为什么比一般项目久？\n",
    "A: start.sh 会安装 Zyphra 定制版 transformers（~30秒）、huggingface_hub（~30秒）和 accelerate（~10秒），总计约 1 分钟。之后 4-7 分钟为模型权重加载时间。\n",
    "\n",
    "### Q: 支持哪些推理模式？\n",
    "A: 支持数学推理、编程、逻辑推理、知识问答。建议 temperature 1.0（通用）/ 0.6（编程）。\n",
    "\n",
    "### Q: 为什么不支持 top_p 参数？\n",
    "A: Zyphra 自定义 transformers（zaya1 分支）不支持 `top_p`/`top_k=-1`。使用 `top_k=50` 替代。\n",
    "\n",
    "### Q: 推理服务里代码放哪里？\n",
    "A: 代码通过推理服务页面上传，自动放到 `/gemini/code/` 目录中。\n",
    "\n",
    "### Q: vLLM 部署怎么配置？\n",
    "A: `vllm serve Zyphra/ZAYA1-8B --port 8010 --mamba-cache-dtype float32 --dtype bfloat16 --reasoning-parser qwen3 --enable-auto-tool-choice --tool-call-parser zaya_xml`\n",
    "\n",
    "---\n",
    "\n",
    "## 七、技术架构\n",
    "\n",
    "```\n",
    "用户输入文本 → Flask Web Server (:5000)\n",
    "    ↓\n",
    "app.py (Zaya1Chat 类)\n",
    "    ↓\n",
    "Zyphra/transformers (zaya1 分支)\n",
    "    ↓\n",
    "PyTorch 2.5.1 + CUDA 12.1\n",
    "    ↓\n",
    "返回推理文本\n",
    "```\n",
    "\n",
    "- 框架：PyTorch 2.5.1\n",
    "- transformers：Zyphra 定制 fork（4.57.1，zaya1 分支），start.sh 自动安装\n",
    "- Python：3.10\n",
    "- OS：Ubuntu 22.04\n",
    "- CUDA：12.1\n",
    "- cuDNN：9（/opt/orion/orion_runtime/gpu/cuda/orion-cuda-12.1）\n",
    "- Web UI：Flask + HTML（纯HTTP，无WebSocket）\n",
    "- 推理引擎：Transformers\n",
    "- 模型格式：Safetensors (bfloat16)\n",
    "- 模型大小：16.5GB / 13 文件\n",
    "\n",
   ]
  }
